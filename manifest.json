{
  "manifest_version": 3,
  "name": "GitHub Education Upload Enabler",
  "version": "1.0",
  "description": "Forces file upload option on GitHub Education benefits page.",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "content_scripts": [
    {
      "matches": ["https://github.com/settings/education/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
